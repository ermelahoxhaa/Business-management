{
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "allowJs": true,
    "checkJs": false,
    "types": [
      "vite/client"
    ]
  },
  "include": [
    "src/**/*",
    "vite.config.js"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
